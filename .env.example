# --- Core state store + checklist (no Redis, no separate DB) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Engine ---
PORT=10000
RUN_MODE=dry                            # dry | live  (global toggle, spec section 04)
# Steps that ALWAYS run their dry path, even when RUN_MODE=live. Lets you go live
# for everything else while keeping the domain/email stack simulated.
STEP_DRY_OVERRIDE=namecheap.purchase_domain,dns.ghl_records,dns.mailgun_records,mailgun.add_domain,warmup.enroll
MMW_WEBHOOK_SECRET=                     # shared secret Zapier sends on the doorbell webhooks
LOOP_INTERVAL_MS=4000                   # how often the checklist loop polls Supabase
JOB_CLAIM_TIMEOUT_MS=300000             # claimed-but-unfinished jobs become reclaimable after this

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_FALLBACK_CHANNEL_ID=

# --- HubSpot ---
HUBSPOT_ACCESS_TOKEN=

# --- ClickUp ---
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=                        # workspace id (from app.clickup.com/<TEAM_ID>/...)
CLICKUP_MASTER_TRACKER_LIST_ID=         # master account tracker LIST (engine appends a client task)
CLICKUP_FOLDER_TEMPLATE_ID=             # client template FOLDER to duplicate per client
CLICKUP_TEMPLATE_SPACE_ID=              # space the duplicated client folder is created in

# --- Google Drive ---
GDRIVE_SA_JSON=
CLIENTS_PARENT_FOLDER_ID=

# --- Namecheap (the money guardrail, spec section 04) ---
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_BASE_URL=https://api.sandbox.namecheap.com
NAMECHEAP_LIVE=false                    # must be true AND a per-run token to purchase
# Optional static-IP egress relay (scripts/namecheap-relay.php) so Namecheap
# calls leave from a whitelisted IP. Set NAMECHEAP_CLIENT_IP to the relay host IP.
NAMECHEAP_RELAY_URL=                     # e.g. https://yoursite.com/ne-relay.php
NAMECHEAP_RELAY_SECRET=

# --- Mailgun ---
MAILGUN_API_KEY=
MAILGUN_REGION=

# --- Warmup Inbox ---
WARMUPINBOX_API_KEY=
# Fixed pool of already-warmed inboxes; new client domains rotate across these.
# Comma-separated emails (set the real ones in Render, not here).
WARMUPINBOX_ROTATION_INBOXES=

# --- GoHighLevel ---
GHL_API_KEY=                             # v2 Private Integration token (agency-level, locations.write scope)
GHL_COMPANY_ID=                          # agency Company ID (required to create sub-accounts)
GHL_SNAPSHOT_ID=
GHL_A2P_CUSTOM_FIELD_MAP=                # M5 only - leave blank for now

# --- DataForSEO ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Google Places ---
GOOGLE_PLACES_API_KEY=

# --- Advice Local ---
ADVICELOCAL_API_KEY=
