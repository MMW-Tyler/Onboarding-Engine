# --- Core state store + checklist (no Redis, no separate DB) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Engine ---
PORT=10000
RUN_MODE=dry                            # dry | live  (global toggle, spec section 04)
MMW_WEBHOOK_SECRET=                     # shared secret Zapier sends on the doorbell webhooks
LOOP_INTERVAL_MS=4000                   # how often the checklist loop polls Supabase
JOB_CLAIM_TIMEOUT_MS=300000             # claimed-but-unfinished jobs become reclaimable after this

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_FALLBACK_CHANNEL_ID=

# --- HubSpot ---
HUBSPOT_ACCESS_TOKEN=

# --- ClickUp ---
CLICKUP_API_TOKEN=
CLICKUP_TEMPLATE_LIST_ID=901712755167
CLICKUP_TEAM_ID=

# --- Google Drive ---
GDRIVE_SA_JSON=
CLIENTS_PARENT_FOLDER_ID=

# --- Namecheap (the money guardrail, spec section 04) ---
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_BASE_URL=https://api.sandbox.namecheap.com
NAMECHEAP_LIVE=false                    # must be true AND a per-run token to purchase

# --- Mailgun ---
MAILGUN_API_KEY=
MAILGUN_REGION=

